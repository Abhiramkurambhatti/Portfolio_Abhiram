# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored so your credentials stay private.

# SMTP server (defaults are for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address (the account that SENDS the email)
SMTP_USER=abhiramkurambhatti@gmail.com

# Gmail App Password (NOT your normal password).
# Create one at: https://myaccount.google.com/apppasswords
# It is 16 characters, e.g. "abcd efgh ijkl mnop" (spaces optional).
SMTP_PASSWORD=your_16_char_app_password

# Where contact-form messages are delivered
CONTACT_RECIPIENT=abhiramkurambhatti@gmail.com
